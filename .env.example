# ==============================================================================
# PROJECT JANUS: ENVIRONMENT CONFIGURATION TEMPLATE (.env)
# ==============================================================================
# Copy this file to '.env' in your local environment and fill in the values.
# Do NOT check your live '.env' file with real credentials into git.

# ------------------------------------------------------------------------------
# 1. DATABASE CONFIGURATIONS
# ------------------------------------------------------------------------------
# Optional: Override the default location of the SQLite database.
# Defaults to: [project-root]/janus.db
# DB_PATH=./janus.db

# Optional: Override the default location of the ChromaDB vector database.
# Defaults to: [project-root]/data/chromadb
# VECTOR_DB_PATH=./data/chromadb

# ------------------------------------------------------------------------------
# 2. LOCAL LLM & EMBEDDING CONFIGURATIONS (Default: Ollama)
# ------------------------------------------------------------------------------
# Base URL for the OpenAI-compatible local/default inference service
LLM_BASE_URL=http://localhost:11434/v1

# API key for the local endpoint (Ollama does not check keys, but needs a placeholder)
LLM_API_KEY=ollama

# Default model used globally across agents unless overridden
LLM_MODEL=qwen2.5-coder:7b

# Embedding model used to index/retrieve semantic memory
EMBEDDING_MODEL=nomic-embed-text

# ------------------------------------------------------------------------------
# 3. MEMORY RELEVANCE FILTERING
# ------------------------------------------------------------------------------
# Distance threshold for memory retrieval. (Lower is closer, representing L2 distance).
# - Relevant context typically scores ~0.5.
# - Unrelated context scores >1.1.
# Setting this prevents irrelevant memories from polluting prompts.
MEMORY_RELEVANCE_THRESHOLD=1.0

# ------------------------------------------------------------------------------
# 4. CLOUD SERVERLESS CONFIGURATION (OpenRouter Integration)
# ------------------------------------------------------------------------------
# If set, any model name containing a slash '/' (e.g. google/gemini-2.5-flash)
# will be automatically routed to OpenRouter.
# OPENROUTER_API_KEY=sk-or-v1-your-real-openrouter-key-here
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ------------------------------------------------------------------------------
# 5. AGENT-SPECIFIC ROUTING OVERRIDES (Optional)
# ------------------------------------------------------------------------------
# You can assign specific models to individual agents. Models with '/' route 
# to OpenRouter, while others route to local Ollama.
#
# Examples:
# PROPOSER_MODEL=google/gemini-2.5-flash
# CRITIC_MODEL=deepseek/deepseek-r1
# EXPLORER_MODEL=qwen2.5-coder:7b
# ARCHIVIST_MODEL=qwen2.5-coder:7b

# You can also explicitly specify a unique host and API key per-agent:
# PROPOSER_BASE_URL=https://openrouter.ai/api/v1
# PROPOSER_API_KEY=sk-or-v1-key
#
# CRITIC_BASE_URL=http://localhost:11434/v1
# CRITIC_API_KEY=ollama

# ------------------------------------------------------------------------------
# 6. HEARTBEAT & DRIVE PACING
# ------------------------------------------------------------------------------
# Pacing interval in minutes when no user input is active (conserves CPU)
# T_IDLE=15

# Pacing interval in seconds when user is actively interacting
# T_ACTIVE=60

# Number of idle ticks before Boredom increments trigger autonomous reflection
# BOREDOM_THRESHOLD=5

# Safety Valve: Max back-to-back autonomous actions allowed without human validation
# N_LOOP_LIMIT=5
