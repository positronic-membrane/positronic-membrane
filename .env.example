# ==============================================================================
# PROJECT JANUS: ENVIRONMENT CONFIGURATION TEMPLATE (.env)
# ==============================================================================
# Copy this file to '.env' and fill in values for your deployment.
# Do NOT commit your live '.env' file — it contains real credentials.

# ------------------------------------------------------------------------------
# 1. DATABASE
# ------------------------------------------------------------------------------
# SQLite (default — no additional config needed):
# DB_PATH=./janus.db
# VECTOR_DB_PATH=./data/chromadb

# PostgreSQL mode — set DB_TYPE and provide a connection URL:
# DB_TYPE=postgres
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ------------------------------------------------------------------------------
# 2. LLM & EMBEDDING (Default: local Ollama)
# ------------------------------------------------------------------------------
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=qwen2.5-coder:7b
EMBEDDING_MODEL=nomic-embed-text

# Set True to skip real LLM calls during development/testing (returns canned responses)
# LLM_MOCK_MODE=False

# Timeout in seconds for a single LLM API call
# LLM_CALL_TIMEOUT=80.0

# Timeout in seconds for a full Persona chat response (includes ReAct loop turns)
# CHAT_TIMEOUT=85

# ------------------------------------------------------------------------------
# 3. MEMORY
# ------------------------------------------------------------------------------
# L2 distance threshold for semantic memory retrieval. Lower = stricter relevance.
# ~0.5 is closely related; >1.1 is typically unrelated.
# MEMORY_RELEVANCE_THRESHOLD=1.0

# Number of granular memories accumulated before consolidation is triggered
# CONSOLIDATION_THRESHOLD=5

# ------------------------------------------------------------------------------
# 4. OPENROUTER (Cloud LLM routing)
# ------------------------------------------------------------------------------
# Any model name containing '/' is automatically routed to OpenRouter.
# OPENROUTER_API_KEY=sk-or-v1-your-key-here
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ------------------------------------------------------------------------------
# 5. AGENT-SPECIFIC MODEL OVERRIDES (Optional)
# ------------------------------------------------------------------------------
# Override the model or endpoint for individual agents.
# Models with '/' route to OpenRouter; others route to local Ollama.
#
# PROPOSER_MODEL=google/gemini-2.5-flash
# CRITIC_MODEL=deepseek/deepseek-r1
# EXPLORER_MODEL=qwen2.5-coder:7b
# ARCHIVIST_MODEL=qwen2.5-coder:7b
#
# Per-agent endpoint/key overrides:
# PROPOSER_BASE_URL=https://openrouter.ai/api/v1
# PROPOSER_API_KEY=sk-or-v1-key
# CRITIC_BASE_URL=http://localhost:11434/v1
# CRITIC_API_KEY=ollama

# ------------------------------------------------------------------------------
# 6. SECURITY & AUTH
# ------------------------------------------------------------------------------
# Set False to disable JWT auth entirely (local dev only — never in production)
# REQUIRE_AUTH=True

# Comma-separated list of allowed CORS origins
# ALLOWED_ORIGINS=http://localhost:5005,http://127.0.0.1:5005

# API rate limiting: max requests per window
# RATE_LIMIT_REQUESTS=60
# RATE_LIMIT_WINDOW=60

# ------------------------------------------------------------------------------
# 7. HEARTBEAT & DRIVE PACING
# ------------------------------------------------------------------------------
# Idle pacing interval in minutes (when no user input is active)
# T_IDLE=15

# Active pacing interval in minutes (when user is interacting)
# T_ACTIVE=1

# Idle ticks before boredom triggers autonomous reflection
# BOREDOM_THRESHOLD=5

# Hard cap on back-to-back autonomous actions without human validation
# N_LOOP_LIMIT=20

# ------------------------------------------------------------------------------
# 8. SANDBOX EXECUTION
# ------------------------------------------------------------------------------
# Executor for sandboxed test suites: "docker" (recommended), "local" (unsafe), "e2b"
# SANDBOX_PROVIDER=docker

# Required only when SANDBOX_PROVIDER=local. Runs pytest directly on the host.
# ALLOW_LOCAL_SANDBOX_EXEC=False

# Docker image used by SANDBOX_PROVIDER=docker. Build with: docker build -t janus:latest .
# JANUS_DOCKER_IMAGE=janus:latest

# Network isolation for the sandbox container ("none" prevents data exfiltration)
# DOCKER_NETWORK=none

# Resource limits for the sandbox container
# DOCKER_MEMORY_LIMIT=512m
# DOCKER_CPU_LIMIT=1.0
# DOCKER_PIDS_LIMIT=256

# Timeout in seconds for the full test suite run inside a sandbox
# SANDBOX_TEST_TIMEOUT=300

# API key for e2b remote micro-VM sandboxes (required when SANDBOX_PROVIDER=e2b)
# E2B_API_KEY=your-e2b-api-key-here

# Backend for spawning child Janus instances: "local", "docker", or "ecs"
# SPAWN_PROVIDER=local

# ------------------------------------------------------------------------------
# 9. GITHUB INTEGRATION
# ------------------------------------------------------------------------------
# Enable the github_integration skill. Requires GITHUB_ACCESS_TOKEN.
# GITHUB_ENABLED=True

# Fine-grained Personal Access Token with Issues: Read/Write and Pull requests: Read/Write.
# Create at: GitHub → Settings → Developer settings → Personal access tokens → Fine-grained tokens
# GITHUB_ACCESS_TOKEN=github_pat_your_token_here

# Default repo used when the skill is called without an explicit repo argument
# GITHUB_REPO=owner/repo

# ------------------------------------------------------------------------------
# 10. SKILLS LIBRARY
# ------------------------------------------------------------------------------
# URL of the janus-skills-library repo cloned at boot for skill sync
# SKILLS_LIBRARY_REPO=git@github.com:jmccauley75gh/janus-skills-library.git

# Branch or tag to check out (defaults to main)
# SKILLS_LIBRARY_REF=main

# ------------------------------------------------------------------------------
# 11. NEO4J GRAPH DATABASE (Optional — for graph memory features)
# ------------------------------------------------------------------------------
# AURA (managed cloud):
# NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=your-password-here
# NEO4J_DATABASE=neo4j

# Self-hosted:
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=your-password-here
# NEO4J_DATABASE=neo4j

# ------------------------------------------------------------------------------
# 12. AWS S3 BACKUP (Optional — nightly database uploads)
# ------------------------------------------------------------------------------
# AWS_ACCESS_KEY_ID=your_access_key_here
# AWS_SECRET_ACCESS_KEY=your_secret_access_key_here
# AWS_S3_BUCKET=your_s3_bucket_name_here
# AWS_DEFAULT_REGION=us-east-1
